    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# GHG Emission Forecasting for ASEAN Countries\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook builds a compact, production-style forecasting workflow for greenhouse gas (GHG) emissions across selected ASEAN countries.\\n\",\n",
    "    \"\\n\",\n",
    "    \"The design goal is practical rather than decorative:\\n\",\n",
    "    \"- keep the pipeline readable for Kaggle reviewers,\\n\",\n",
    "    \"- keep the code lean by removing unused outputs and redundant structures,\\n\",\n",
    "    \"- evaluate each forecast with rolling backtesting,\\n\",\n",
    "    \"- generate a configurable multi-year forecast from a single parameter block at the top.\\n\"\n",
    "   ],\n",
    "   \"id\": \"d1454fe17df1e653\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Notebook structure\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. Define the global configuration.\\n\",\n",
    "    \"2. Load and standardize the source tables.\\n\",\n",
    "    \"3. Build country-level features with lag selection.\\n\",\n",
    "    \"4. Compare several forecasting candidates with rolling backtests.\\n\",\n",
    "    \"5. Export two final outputs:\\n\",\n",
    "    \"   - `country_model_evaluation.csv`\\n\",\n",
    "    \"   - `country_ghg_forecast_<start>_<end>.csv`\\n\",\n",
    "    \"\\n\",\n",
    "    \"This version intentionally avoids extra artifacts such as lag summaries, backtest prediction tables, candidate dumps, and run summaries, because they add noise without helping the final deliverable.\\n\"\n",
    "   ],\n",
    "   \"id\": \"3dc43752b999c298\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-05-07T08:46:22.050917Z\",\n",
    "     \"start_time\": \"2026-05-07T08:46:21.867257Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"from __future__ import annotations\\n\",\n",
    "    \"\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import warnings\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from IPython.display import display\\n\",\n",
    "    \"from scipy import stats\\n\",\n",
    "    \"from scipy.stats import ConstantInputWarning\\n\",\n",
    "    \"from sklearn.ensemble import HistGradientBoostingRegressor\\n\",\n",
    "    \"from sklearn.impute import SimpleImputer\\n\",\n",
    "    \"from sklearn.linear_model import Ridge\\n\",\n",
    "    \"from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score\\n\",\n",
    "    \"from sklearn.pipeline import Pipeline\\n\",\n",
    "    \"from sklearn.preprocessing import StandardScaler\\n\",\n",
    "    \"\\n\",\n",
    "    \"os.environ.setdefault(\\\"LOKY_MAX_CPU_COUNT\\\", \\\"4\\\")\\n\",\n",
    "    \"warnings.filterwarnings(\\\"ignore\\\", category=ConstantInputWarning)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Core settings. These are the main values to adjust before rerunning the notebook.\\n\",\n",
    "    \"COUNTRIES = [\\n\",\n",
    "    \"    \\\"Brunei Darussalam\\\",\\n\",\n",
    "    \"    \\\"Timor-Leste\\\",\\n\",\n",
    "    \"    \\\"Cambodia\\\",\\n\",\n",
    "    \"    \\\"Indonesia\\\",\\n\",\n",
    "    \"    \\\"Lao PDR\\\",\\n\",\n",
    "    \"    \\\"Malaysia\\\",\\n\",\n",
    "    \"    \\\"Myanmar\\\",\\n\",\n",
    "    \"    \\\"Philippines\\\",\\n\",\n",
    "    \"    \\\"Singapore\\\",\\n\",\n",
    "    \"    \\\"Thailand\\\",\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"EXOGENOUS_FEATURES = [\\n\",\n",
    "    \"    \\\"temperature\\\",\\n\",\n",
    "    \"    \\\"energy_consumption\\\",\\n\",\n",
    "    \"    \\\"sustainable_energy\\\",\\n\",\n",
    "    \"    \\\"forest_area_pct\\\",\\n\",\n",
    "    \"    \\\"gdp_per_capita\\\",\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"AUTOREGRESSIVE_LAGS = 5\\n\",\n",
    "    \"MAX_EXOGENOUS_LAG = 5\\n\",\n",
    "    \"MIN_TRAIN_SIZE = 18\\n\",\n",
    "    \"MAX_BACKTEST_YEARS = 6\\n\",\n",
    "    \"FORECAST_YEARS = 5\\n\",\n",
    "    \"FLOAT_PRECISION = 3\\n\",\n",
    "    \"\\n\",\n",
    "    \"# The notebook first looks for the local folder, then a common Kaggle input folder.\\n\",\n",
    "    \"DATA_ROOT_CANDIDATES = [\\n\",\n",
    "    \"    Path(\\\"data_effect_climate_change\\\"),\\n\",\n",
    "    \"    Path(\\\"/kaggle/input/data-effect-climate-change\\\"),\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"DATA_ROOT = next((path for path in DATA_ROOT_CANDIDATES if path.exists()), DATA_ROOT_CANDIDATES[0])\\n\",\n",
    "    \"\\n\",\n",
    "    \"SOURCE_FILES = {\\n\",\n",
    "    \"    \\\"ghg_current\\\": (\\\"OWID_CB_TOTAL_GHG_WIDEF.ods\\\", \\\"excel\\\"),\\n\",\n",
    "    \"    \\\"temperature\\\": (\\\"WB_CCKP_TAS_WIDEF.csv\\\", \\\"csv\\\"),\\n\",\n",
    "    \"    \\\"energy_consumption\\\": (\\\"OWID_CB_PRIMARY_ENERGY_CONSUMPTION_WIDEF.csv\\\", \\\"csv\\\"),\\n\",\n",
    "    \"    \\\"sustainable_energy\\\": (\\\"WB_SE4ALL_EG_FCON_RNEW_WIDEF.csv\\\", \\\"csv\\\"),\\n\",\n",
    "    \"    \\\"forest_area_pct\\\": (\\\"WB_WDI_AG_LND_FRST_ZS_WIDEF.csv\\\", \\\"csv\\\"),\\n\",\n",
    "    \"    \\\"gdp_per_capita\\\": (\\\"WB_WDI_NY_GDP_PCAP_KN_WIDEF.csv\\\", \\\"csv\\\"),\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Using data root: {DATA_ROOT}\\\")\\n\"\n",
    "   ],\n",
    "   \"id\": \"c581e5422dc48a7b\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Using data root: data_effect_climate_change\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 1\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Load the source data\\n\",\n",
    "    \"\\n\",\n",
    "    \"The raw files are wide-format country tables. The helper functions below keep the loading logic centralized so the rest of the notebook can stay focused on modeling.\\n\"\n",
    "   ],\n",
    "   \"id\": \"5a174c69bbe552f7\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-05-07T08:46:23.340247Z\",\n",
    "     \"start_time\": \"2026-05-07T08:46:22.052305Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"def load_sources(data_root: Path) -> dict[str, pd.DataFrame]:\\n\",\n",
    "    \"    \\\"\\\"\\\"Load all raw source tables once.\\\"\\\"\\\"\\n\",\n",
    "    \"    sources: dict[str, pd.DataFrame] = {}\\n\",\n",
    "    \"    for feature_name, (file_name, file_type) in SOURCE_FILES.items():\\n\",\n",
    "    \"        file_path = data_root / file_name\\n\",\n",
    "    \"        if file_type == \\\"excel\\\":\\n\",\n",
    "    \"            sources[feature_name] = pd.read_excel(file_path)\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            sources[feature_name] = pd.read_csv(file_path)\\n\",\n",
    "    \"    return sources\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def extract_country_series(country: str, frame: pd.DataFrame, min_year: int = 1950) -> pd.Series:\\n\",\n",
    "    \"    \\\"\\\"\\\"Convert one country's wide table into a numeric time series indexed by year.\\\"\\\"\\\"\\n\",\n",
    "    \"    frame = frame.copy()\\n\",\n",
    "    \"    frame.columns = frame.columns.astype(str)\\n\",\n",
    "    \"    matches = frame.index[frame[\\\"REF_AREA_LABEL\\\"] == country]\\n\",\n",
    "    \"    if len(matches) == 0:\\n\",\n",
    "    \"        raise KeyError(f\\\"{country} is missing from source data.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    year_cols = sorted(\\n\",\n",
    "    \"        [column for column in frame.columns if column.isdigit() and min_year <= int(column) <= 2100],\\n\",\n",
    "    \"        key=int,\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    series = pd.to_numeric(frame.loc[matches[0], year_cols], errors=\\\"coerce\\\")\\n\",\n",
    "    \"    series.index = pd.Index([int(year) for year in year_cols], name=\\\"year\\\")\\n\",\n",
    "    \"    return series.astype(float).sort_index()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"sources = load_sources(DATA_ROOT)\\n\",\n",
    "    \"print(f\\\"Loaded {len(sources)} source tables.\\\")\\n\"\n",
    "   ],\n",
    "   \"id\": \"da485203b3130922\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Loaded 6 source tables.\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 2\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Feature engineering\\n\",\n",
    "    \"\\n\",\n",
    "    \"The model uses three feature groups:\\n\",\n",
    "    \"- autoregressive GHG history,\\n\",\n",
    "    \"- rolling statistics and short-term growth features,\\n\",\n",
    "    \"- exogenous indicators aligned with country-specific optimal lags.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Using a compact helper layer keeps the panel-building logic reproducible and easier to audit.\\n\"\n",
    "   ],\n",
    "   \"id\": \"903686e6b03cbd8a\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-05-07T08:46:23.372813Z\",\n",
    "     \"start_time\": \"2026-05-07T08:46:23.361424Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"def safe_pct_change(series: pd.Series, periods: int = 1) -> pd.Series:\\n\",\n",
    "    \"    return series.pct_change(periods=periods, fill_method=None).replace([np.inf, -np.inf], np.nan)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def compute_optimal_lag(target: pd.Series, variable: pd.Series, max_lag: int) -> int:\\n\",\n",
    "    \"    \\\"\\\"\\\"Pick the lag with the strongest absolute Spearman correlation.\\\"\\\"\\\"\\n\",\n",
    "    \"    best_lag = 0\\n\",\n",
    "    \"    best_abs_rho = -1.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for lag in range(max_lag + 1):\\n\",\n",
    "    \"        trial = pd.DataFrame({\\\"target\\\": target, \\\"variable\\\": variable.shift(lag)}).dropna()\\n\",\n",
    "    \"        if len(trial) < 3:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"        rho, _ = stats.spearmanr(trial[\\\"variable\\\"], trial[\\\"target\\\"])\\n\",\n",
    "    \"        if pd.notna(rho) and abs(rho) > best_abs_rho:\\n\",\n",
    "    \"            best_lag = lag\\n\",\n",
    "    \"            best_abs_rho = abs(rho)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return best_lag\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def build_country_panel(country: str, sources: dict[str, pd.DataFrame]) -> tuple[pd.DataFrame, list[str]]:\\n\",\n",
    "    \"    \\\"\\\"\\\"Build a modeling table for one country.\\\"\\\"\\\"\\n\",\n",
    "    \"    series_map = {name: extract_country_series(country, frame) for name, frame in sources.items()}\\n\",\n",
    "    \"    ghg = series_map[\\\"ghg_current\\\"]\\n\",\n",
    "    \"    lags = {\\n\",\n",
    "    \"        feature_name: compute_optimal_lag(ghg, series_map[feature_name], MAX_EXOGENOUS_LAG)\\n\",\n",
    "    \"        for feature_name in EXOGENOUS_FEATURES\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    years = sorted(ghg.index)\\n\",\n",
    "    \"    panel = pd.DataFrame({\\\"year\\\": years, \\\"country\\\": country})\\n\",\n",
    "    \"    panel[\\\"ghg_current\\\"] = ghg.reindex(years).values\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for feature_name, lag in lags.items():\\n\",\n",
    "    \"        panel[feature_name] = series_map[feature_name].shift(lag).reindex(years).values\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for lag in range(1, AUTOREGRESSIVE_LAGS + 1):\\n\",\n",
    "    \"        panel[f\\\"ghg_lag{lag}\\\"] = panel[\\\"ghg_current\\\"].shift(lag)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    panel[\\\"ghg_roll3\\\"] = panel[\\\"ghg_current\\\"].shift(1).rolling(3).mean()\\n\",\n",
    "    \"    panel[\\\"ghg_roll5\\\"] = panel[\\\"ghg_current\\\"].shift(1).rolling(5).mean()\\n\",\n",
    "    \"    panel[\\\"ghg_std3\\\"] = panel[\\\"ghg_current\\\"].shift(1).rolling(3).std()\\n\",\n",
    "    \"    panel[\\\"ghg_diff1\\\"] = panel[\\\"ghg_current\\\"].diff(1)\\n\",\n",
    "    \"    panel[\\\"ghg_diff2\\\"] = panel[\\\"ghg_current\\\"].diff(2)\\n\",\n",
    "    \"    panel[\\\"ghg_growth1\\\"] = safe_pct_change(panel[\\\"ghg_current\\\"], periods=1)\\n\",\n",
    "    \"    panel[\\\"year_index\\\"] = panel[\\\"year\\\"] - panel[\\\"year\\\"].min()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    feature_cols = [\\n\",\n",
    "    \"        \\\"year\\\",\\n\",\n",
    "    \"        \\\"year_index\\\",\\n\",\n",
    "    \"        \\\"ghg_current\\\",\\n\",\n",
    "    \"        *[f\\\"ghg_lag{lag}\\\" for lag in range(1, AUTOREGRESSIVE_LAGS + 1)],\\n\",\n",
    "    \"        \\\"ghg_roll3\\\",\\n\",\n",
    "    \"        \\\"ghg_roll5\\\",\\n\",\n",
    "    \"        \\\"ghg_std3\\\",\\n\",\n",
    "    \"        \\\"ghg_diff1\\\",\\n\",\n",
    "    \"        \\\"ghg_diff2\\\",\\n\",\n",
    "    \"        \\\"ghg_growth1\\\",\\n\",\n",
    "    \"        *EXOGENOUS_FEATURES,\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"    return panel, feature_cols\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def build_training_frame(panel: pd.DataFrame, horizon_years: int) -> pd.DataFrame:\\n\",\n",
    "    \"    training_df = panel.copy()\\n\",\n",
    "    \"    training_df[\\\"target_ghg\\\"] = training_df[\\\"ghg_current\\\"].shift(-horizon_years)\\n\",\n",
    "    \"    training_df[\\\"target_delta\\\"] = training_df[\\\"target_ghg\\\"] - training_df[\\\"ghg_current\\\"]\\n\",\n",
    "    \"    return training_df.dropna(subset=[\\\"target_ghg\\\"]).reset_index(drop=True)\\n\"\n",
    "   ],\n",
    "   \"id\": \"cda8115ad2f9fc00\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 3\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Candidate models and validation logic\\n\",\n",
    "    \"\\n\",\n",
    "    \"The notebook compares a small set of forecasting candidates:\\n\",\n",
    "    \"- persistence baseline,\\n\",\n",
    "    \"- recent-average baseline,\\n\",\n",
    "    \"- short linear trend,\\n\",\n",
    "    \"- ridge regression on delta,\\n\",\n",
    "    \"- histogram gradient boosting on a log target.\\n\",\n",
    "    \"\\n\",\n",
    "    \"The final model for each horizon is selected using rolling backtest RMSE, with MAE and a deterministic model ranking used as tie-breakers.\\n\"\n",
    "   ],\n",
    "   \"id\": \"c26c515b56cf4f6e\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-05-07T08:46:23.541047Z\",\n",
    "     \"start_time\": \"2026-05-07T08:46:23.373638Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"def fit_naive(_: pd.DataFrame, __: list[str]):\\n\",\n",
    "    \"    return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def predict_naive(_: object, feature_row: pd.DataFrame, __: pd.Series, ___: list[str], ____: int) -> float:\\n\",\n",
    "    \"    return max(0.0, float(feature_row[\\\"ghg_current\\\"].iloc[0]))\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def fit_mean3(_: pd.DataFrame, __: list[str]):\\n\",\n",
    "    \"    return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def predict_mean3(_: object, __: pd.DataFrame, history: pd.Series, ___: list[str], ____: int) -> float:\\n\",\n",
    "    \"    recent = history.dropna().tail(3)\\n\",\n",
    "    \"    return np.nan if recent.empty else max(0.0, float(recent.mean()))\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def fit_trend5(_: pd.DataFrame, __: list[str]):\\n\",\n",
    "    \"    return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def predict_trend5(_: object, __: pd.DataFrame, history: pd.Series, ___: list[str], horizon_years: int) -> float:\\n\",\n",
    "    \"    observed = history.dropna().astype(float).sort_index().tail(5)\\n\",\n",
    "    \"    if observed.empty:\\n\",\n",
    "    \"        return np.nan\\n\",\n",
    "    \"    if len(observed) == 1:\\n\",\n",
    "    \"        return float(observed.iloc[-1])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    x = observed.index.to_numpy(dtype=float)\\n\",\n",
    "    \"    y = observed.to_numpy(dtype=float)\\n\",\n",
    "    \"    slope, intercept = np.polyfit(x, y, 1)\\n\",\n",
    "    \"    forecast_year = float(x[-1] + horizon_years)\\n\",\n",
    "    \"    return max(0.0, float(slope * forecast_year + intercept))\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def fit_ridge_delta(train_df: pd.DataFrame, feature_cols: list[str]) -> Pipeline:\\n\",\n",
    "    \"    model = Pipeline(\\n\",\n",
    "    \"        [\\n\",\n",
    "    \"            (\\\"imputer\\\", SimpleImputer(strategy=\\\"median\\\")),\\n\",\n",
    "    \"            (\\\"scaler\\\", StandardScaler()),\\n\",\n",
    "    \"            (\\\"model\\\", Ridge(alpha=1.0)),\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    model.fit(train_df[feature_cols], train_df[\\\"target_delta\\\"])\\n\",\n",
    "    \"    return model\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def predict_ridge_delta(model: Pipeline, feature_row: pd.DataFrame, _: pd.Series, feature_cols: list[str], __: int) -> float:\\n\",\n",
    "    \"    current = float(feature_row[\\\"ghg_current\\\"].iloc[0])\\n\",\n",
    "    \"    delta = float(model.predict(feature_row[feature_cols])[0])\\n\",\n",
    "    \"    return max(0.0, current + delta)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def fit_histgb_log(train_df: pd.DataFrame, feature_cols: list[str]) -> Pipeline:\\n\",\n",
    "    \"    model = Pipeline(\\n\",\n",
    "    \"        [\\n\",\n",
    "    \"            (\\\"imputer\\\", SimpleImputer(strategy=\\\"median\\\")),\\n\",\n",
    "    \"            (\\n\",\n",
    "    \"                \\\"model\\\",\\n\",\n",
    "    \"                HistGradientBoostingRegressor(\\n\",\n",
    "    \"                    learning_rate=0.05,\\n\",\n",
    "    \"                    max_depth=3,\\n\",\n",
    "    \"                    max_iter=300,\\n\",\n",
    "    \"                    l2_regularization=0.1,\\n\",\n",
    "    \"                    random_state=42,\\n\",\n",
    "    \"                ),\\n\",\n",
    "    \"            ),\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    target = np.log1p(np.clip(train_df[\\\"target_ghg\\\"].to_numpy(dtype=float), 0.0, None))\\n\",\n",
    "    \"    model.fit(train_df[feature_cols], target)\\n\",\n",
    "    \"    return model\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def predict_histgb_log(model: Pipeline, feature_row: pd.DataFrame, _: pd.Series, feature_cols: list[str], __: int) -> float:\\n\",\n",
    "    \"    prediction = float(np.expm1(model.predict(feature_row[feature_cols])[0]))\\n\",\n",
    "    \"    return max(0.0, prediction)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"MODEL_CANDIDATES = [\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"name\\\": \\\"naive\\\",\\n\",\n",
    "    \"        \\\"family\\\": \\\"baseline_persistence\\\",\\n\",\n",
    "    \"        \\\"fit\\\": fit_naive,\\n\",\n",
    "    \"        \\\"predict\\\": predict_naive,\\n\",\n",
    "    \"    },\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"name\\\": \\\"mean3\\\",\\n\",\n",
    "    \"        \\\"family\\\": \\\"baseline_recent_average\\\",\\n\",\n",
    "    \"        \\\"fit\\\": fit_mean3,\\n\",\n",
    "    \"        \\\"predict\\\": predict_mean3,\\n\",\n",
    "    \"    },\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"name\\\": \\\"trend5\\\",\\n\",\n",
    "    \"        \\\"family\\\": \\\"baseline_recent_linear_trend\\\",\\n\",\n",
    "    \"        \\\"fit\\\": fit_trend5,\\n\",\n",
    "    \"        \\\"predict\\\": predict_trend5,\\n\",\n",
    "    \"    },\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"name\\\": \\\"ridge_delta\\\",\\n\",\n",
    "    \"        \\\"family\\\": \\\"regularized_linear_delta\\\",\\n\",\n",
    "    \"        \\\"fit\\\": fit_ridge_delta,\\n\",\n",
    "    \"        \\\"predict\\\": predict_ridge_delta,\\n\",\n",
    "    \"    },\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"name\\\": \\\"histgb_log\\\",\\n\",\n",
    "    \"        \\\"family\\\": \\\"boosted_tree_log_target\\\",\\n\",\n",
    "    \"        \\\"fit\\\": fit_histgb_log,\\n\",\n",
    "    \"        \\\"predict\\\": predict_histgb_log,\\n\",\n",
    "    \"    },\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"MODEL_LOOKUP = {spec[\\\"name\\\"]: spec for spec in MODEL_CANDIDATES}\\n\",\n",
    "    \"MODEL_RANK = {\\\"naive\\\": 0, \\\"mean3\\\": 1, \\\"trend5\\\": 2, \\\"ridge_delta\\\": 3, \\\"histgb_log\\\": 4}\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def mape(y_true: np.ndarray, y_pred: np.ndarray) -> float:\\n\",\n",
    "    \"    y_true = np.asarray(y_true, dtype=float)\\n\",\n",
    "    \"    y_pred = np.asarray(y_pred, dtype=float)\\n\",\n",
    "    \"    mask = y_true != 0\\n\",\n",
    "    \"    if mask.sum() == 0:\\n\",\n",
    "    \"        return np.nan\\n\",\n",
    "    \"    return float(np.mean(np.abs((y_true[mask] - y_pred[mask]) / y_true[mask])) * 100.0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def reliability_tier(rmse: float, naive_rmse: float) -> str:\\n\",\n",
    "    \"    if pd.isna(rmse) or pd.isna(naive_rmse):\\n\",\n",
    "    \"        return \\\"low\\\"\\n\",\n",
    "    \"    if rmse <= naive_rmse * 0.95:\\n\",\n",
    "    \"        return \\\"high\\\"\\n\",\n",
    "    \"    if rmse <= naive_rmse * 1.05:\\n\",\n",
    "    \"        return \\\"medium\\\"\\n\",\n",
    "    \"    return \\\"low\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def choose_best_candidate(metrics_df: pd.DataFrame) -> pd.Series:\\n\",\n",
    "    \"    ranked = metrics_df.assign(model_rank=metrics_df[\\\"candidate_model\\\"].map(MODEL_RANK).fillna(99))\\n\",\n",
    "    \"    return ranked.sort_values([\\\"rmse_mtco2e\\\", \\\"mae_mtco2e\\\", \\\"model_rank\\\"]).iloc[0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def build_backtest_history(train_df: pd.DataFrame, test_row: pd.DataFrame) -> pd.Series:\\n\",\n",
    "    \"    history = pd.concat(\\n\",\n",
    "    \"        [train_df[[\\\"year\\\", \\\"ghg_current\\\"]], test_row[[\\\"year\\\", \\\"ghg_current\\\"]]],\\n\",\n",
    "    \"        ignore_index=True,\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    return history.drop_duplicates(\\\"year\\\", keep=\\\"last\\\").sort_values(\\\"year\\\").set_index(\\\"year\\\")[\\\"ghg_current\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def run_rolling_backtest(panel: pd.DataFrame, feature_cols: list[str], country: str, horizon_years: int) -> pd.DataFrame:\\n\",\n",
    "    \"    training_df = build_training_frame(panel, horizon_years).sort_values(\\\"year\\\").reset_index(drop=True)\\n\",\n",
    "    \"    available_splits = len(training_df) - MIN_TRAIN_SIZE\\n\",\n",
    "    \"    if available_splits < 3:\\n\",\n",
    "    \"        return pd.DataFrame()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    n_splits = min(MAX_BACKTEST_YEARS, available_splits)\\n\",\n",
    "    \"    test_start = len(training_df) - n_splits\\n\",\n",
    "    \"    metric_rows = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for spec in MODEL_CANDIDATES:\\n\",\n",
    "    \"        predictions = []\\n\",\n",
    "    \"        for test_idx in range(test_start, len(training_df)):\\n\",\n",
    "    \"            train_slice = training_df.iloc[:test_idx].copy()\\n\",\n",
    "    \"            test_row = training_df.iloc[[test_idx]].copy()\\n\",\n",
    "    \"            history = build_backtest_history(train_slice, test_row)\\n\",\n",
    "    \"            model = spec[\\\"fit\\\"](train_slice, feature_cols)\\n\",\n",
    "    \"            prediction = spec[\\\"predict\\\"](model, test_row, history, feature_cols, horizon_years)\\n\",\n",
    "    \"            predictions.append(\\n\",\n",
    "    \"                {\\n\",\n",
    "    \"                    \\\"actual_ghg_mtco2e\\\": float(test_row[\\\"target_ghg\\\"].iloc[0]),\\n\",\n",
    "    \"                    \\\"predicted_ghg_mtco2e\\\": float(prediction),\\n\",\n",
    "    \"                }\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        prediction_df = pd.DataFrame(predictions)\\n\",\n",
    "    \"        actual = prediction_df[\\\"actual_ghg_mtco2e\\\"].to_numpy(dtype=float)\\n\",\n",
    "    \"        predicted = prediction_df[\\\"predicted_ghg_mtco2e\\\"].to_numpy(dtype=float)\\n\",\n",
    "    \"        metric_rows.append(\\n\",\n",
    "    \"            {\\n\",\n",
    "    \"                \\\"country\\\": country,\\n\",\n",
    "    \"                \\\"forecast_horizon_years\\\": horizon_years,\\n\",\n",
    "    \"                \\\"candidate_model\\\": spec[\\\"name\\\"],\\n\",\n",
    "    \"                \\\"candidate_family\\\": spec[\\\"family\\\"],\\n\",\n",
    "    \"                \\\"backtest_years\\\": len(prediction_df),\\n\",\n",
    "    \"                \\\"rmse_mtco2e\\\": float(np.sqrt(mean_squared_error(actual, predicted))),\\n\",\n",
    "    \"                \\\"mae_mtco2e\\\": float(mean_absolute_error(actual, predicted)),\\n\",\n",
    "    \"                \\\"mape_pct\\\": float(mape(actual, predicted)),\\n\",\n",
    "    \"                \\\"r2\\\": float(r2_score(actual, predicted)) if len(prediction_df) > 1 else np.nan,\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return pd.DataFrame(metric_rows)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def forecast_country(country: str, panel: pd.DataFrame, feature_cols: list[str]) -> tuple[dict[str, object] | None, pd.DataFrame]:\\n\",\n",
    "    \"    metrics_by_horizon: dict[int, pd.DataFrame] = {}\\n\",\n",
    "    \"    for horizon_years in range(1, FORECAST_YEARS + 1):\\n\",\n",
    "    \"        metrics_df = run_rolling_backtest(panel, feature_cols, country, horizon_years)\\n\",\n",
    "    \"        if not metrics_df.empty:\\n\",\n",
    "    \"            metrics_by_horizon[horizon_years] = metrics_df\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if 1 not in metrics_by_horizon:\\n\",\n",
    "    \"        return None, pd.DataFrame()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    latest_feature_row = panel.sort_values(\\\"year\\\").tail(1).copy()\\n\",\n",
    "    \"    latest_observed_year = int(latest_feature_row[\\\"year\\\"].iloc[0])\\n\",\n",
    "    \"    history = panel.dropna(subset=[\\\"ghg_current\\\"]).sort_values(\\\"year\\\").set_index(\\\"year\\\")[\\\"ghg_current\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    one_year_metrics = metrics_by_horizon[1]\\n\",\n",
    "    \"    best_one_year = choose_best_candidate(one_year_metrics)\\n\",\n",
    "    \"    one_year_benchmark = one_year_metrics.loc[one_year_metrics[\\\"candidate_model\\\"] == \\\"naive\\\"].iloc[0]\\n\",\n",
    "    \"    one_year_rmse = float(best_one_year[\\\"rmse_mtco2e\\\"])\\n\",\n",
    "    \"    one_year_naive_rmse = float(one_year_benchmark[\\\"rmse_mtco2e\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    evaluation_row = {\\n\",\n",
    "    \"        \\\"country\\\": country,\\n\",\n",
    "    \"        \\\"selected_model\\\": str(best_one_year[\\\"candidate_model\\\"]),\\n\",\n",
    "    \"        \\\"selected_model_family\\\": str(best_one_year[\\\"candidate_family\\\"]),\\n\",\n",
    "    \"        \\\"backtest_years\\\": int(best_one_year[\\\"backtest_years\\\"]),\\n\",\n",
    "    \"        \\\"train_rows_full\\\": int(len(build_training_frame(panel, 1))),\\n\",\n",
    "    \"        \\\"latest_observed_year\\\": latest_observed_year,\\n\",\n",
    "    \"        \\\"forecast_horizon_years\\\": 1,\\n\",\n",
    "    \"        \\\"rmse_mtco2e\\\": one_year_rmse,\\n\",\n",
    "    \"        \\\"mae_mtco2e\\\": float(best_one_year[\\\"mae_mtco2e\\\"]),\\n\",\n",
    "    \"        \\\"mape_pct\\\": float(best_one_year[\\\"mape_pct\\\"]),\\n\",\n",
    "    \"        \\\"r2\\\": float(best_one_year[\\\"r2\\\"]),\\n\",\n",
    "    \"        \\\"benchmark_model\\\": \\\"naive\\\",\\n\",\n",
    "    \"        \\\"benchmark_rmse_mtco2e\\\": one_year_naive_rmse,\\n\",\n",
    "    \"        \\\"benchmark_mae_mtco2e\\\": float(one_year_benchmark[\\\"mae_mtco2e\\\"]),\\n\",\n",
    "    \"        \\\"rmse_improvement_vs_benchmark_mtco2e\\\": one_year_naive_rmse - one_year_rmse,\\n\",\n",
    "    \"        \\\"rmse_improvement_vs_benchmark_pct\\\": (\\n\",\n",
    "    \"            (one_year_naive_rmse - one_year_rmse) / one_year_naive_rmse * 100.0 if one_year_naive_rmse != 0 else np.nan\\n\",\n",
    "    \"        ),\\n\",\n",
    "    \"        \\\"reliability_tier\\\": reliability_tier(one_year_rmse, one_year_naive_rmse),\\n\",\n",
    "    \"        \\\"validation_strategy\\\": \\\"rolling_one_step_backtest_with_model_selection\\\",\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    forecast_rows = []\\n\",\n",
    "    \"    for horizon_years, metrics_df in metrics_by_horizon.items():\\n\",\n",
    "    \"        best_candidate = choose_best_candidate(metrics_df)\\n\",\n",
    "    \"        benchmark_row = metrics_df.loc[metrics_df[\\\"candidate_model\\\"] == \\\"naive\\\"].iloc[0]\\n\",\n",
    "    \"        spec = MODEL_LOOKUP[str(best_candidate[\\\"candidate_model\\\"])]\\n\",\n",
    "    \"        training_df = build_training_frame(panel, horizon_years)\\n\",\n",
    "    \"        fitted_model = spec[\\\"fit\\\"](training_df, feature_cols)\\n\",\n",
    "    \"        prediction = spec[\\\"predict\\\"](fitted_model, latest_feature_row, history, feature_cols, horizon_years)\\n\",\n",
    "    \"        previous_value = float(history.iloc[-1])\\n\",\n",
    "    \"        yoy_change = prediction - previous_value\\n\",\n",
    "    \"\\n\",\n",
    "    \"        forecast_rows.append(\\n\",\n",
    "    \"            {\\n\",\n",
    "    \"                \\\"country\\\": country,\\n\",\n",
    "    \"                \\\"latest_observed_year\\\": latest_observed_year,\\n\",\n",
    "    \"                \\\"source_year\\\": latest_observed_year,\\n\",\n",
    "    \"                \\\"predict_for_year\\\": latest_observed_year + horizon_years,\\n\",\n",
    "    \"                \\\"forecast_horizon_years\\\": horizon_years,\\n\",\n",
    "    \"                \\\"selected_model\\\": spec[\\\"name\\\"],\\n\",\n",
    "    \"                \\\"selected_model_family\\\": spec[\\\"family\\\"],\\n\",\n",
    "    \"                \\\"predicted_ghg_mtco2e\\\": prediction,\\n\",\n",
    "    \"                \\\"previous_ghg_mtco2e\\\": previous_value,\\n\",\n",
    "    \"                \\\"yoy_change_mtco2e\\\": yoy_change,\\n\",\n",
    "    \"                \\\"yoy_change_pct\\\": yoy_change / previous_value * 100.0 if previous_value != 0 else np.nan,\\n\",\n",
    "    \"                \\\"backtest_rmse_mtco2e\\\": float(best_candidate[\\\"rmse_mtco2e\\\"]),\\n\",\n",
    "    \"                \\\"benchmark_rmse_mtco2e\\\": float(benchmark_row[\\\"rmse_mtco2e\\\"]),\\n\",\n",
    "    \"                \\\"rmse_improvement_vs_benchmark_mtco2e\\\": float(benchmark_row[\\\"rmse_mtco2e\\\"] - best_candidate[\\\"rmse_mtco2e\\\"]),\\n\",\n",
    "    \"                \\\"reliability_tier\\\": reliability_tier(float(best_candidate[\\\"rmse_mtco2e\\\"]), float(benchmark_row[\\\"rmse_mtco2e\\\"])),\\n\",\n",
    "    \"                \\\"forecast_basis\\\": \\\"direct_horizon_model_selection\\\",\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return evaluation_row, pd.DataFrame(forecast_rows)\\n\"\n",
    "   ],\n",
