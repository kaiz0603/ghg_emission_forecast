    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Run the full pipeline\\n\",\n",
    "    \"\\n\",\n",
    "    \"This cell trains and evaluates each country independently, then writes the final outputs to the working directory.\\n\",\n",
    "    \"\\n\",\n",
    "    \"To change the forecast horizon, update `FORECAST_YEARS` in the configuration cell and rerun the notebook.\\n\"\n",
    "   ],\n",
    "   \"id\": \"5da2a5c7add80972\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-05-07T08:46:42.736908Z\",\n",
    "     \"start_time\": \"2026-05-07T08:46:23.547464Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"def round_numeric(df: pd.DataFrame, digits: int = FLOAT_PRECISION) -> pd.DataFrame:\\n\",\n",
    "    \"    if df.empty:\\n\",\n",
    "    \"        return df.copy()\\n\",\n",
    "    \"    rounded = df.copy()\\n\",\n",
    "    \"    numeric_cols = rounded.select_dtypes(include=[\\\"number\\\"]).columns\\n\",\n",
    "    \"    rounded[numeric_cols] = rounded[numeric_cols].round(digits)\\n\",\n",
    "    \"    return rounded\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"evaluation_rows = []\\n\",\n",
    "    \"forecast_frames = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"for country in COUNTRIES:\\n\",\n",
    "    \"    panel, feature_cols = build_country_panel(country, sources)\\n\",\n",
    "    \"    evaluation_row, forecast_df = forecast_country(country, panel, feature_cols)\\n\",\n",
    "    \"    if evaluation_row is not None:\\n\",\n",
    "    \"        evaluation_rows.append(evaluation_row)\\n\",\n",
    "    \"    if not forecast_df.empty:\\n\",\n",
    "    \"        forecast_frames.append(forecast_df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"evaluation_df = pd.DataFrame(evaluation_rows)\\n\",\n",
    "    \"if not evaluation_df.empty:\\n\",\n",
    "    \"    evaluation_df = round_numeric(\\n\",\n",
    "    \"        evaluation_df\\n\",\n",
    "    \"        .sort_values([\\\"forecast_horizon_years\\\", \\\"reliability_tier\\\", \\\"rmse_mtco2e\\\", \\\"country\\\"])\\n\",\n",
    "    \"        .reset_index(drop=True)\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"multi_year_df = pd.concat(forecast_frames, ignore_index=True) if forecast_frames else pd.DataFrame()\\n\",\n",
    "    \"if not multi_year_df.empty:\\n\",\n",
    "    \"    multi_year_df = round_numeric(\\n\",\n",
    "    \"        multi_year_df.sort_values([\\\"country\\\", \\\"predict_for_year\\\"]).reset_index(drop=True)\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"forecast_file_name = f\\\"country_ghg_forecast_{FORECAST_YEARS}_years.csv\\\"\\n\",\n",
    "    \"if not multi_year_df.empty:\\n\",\n",
    "    \"    start_year = int(multi_year_df[\\\"predict_for_year\\\"].min())\\n\",\n",
    "    \"    end_year = int(multi_year_df[\\\"predict_for_year\\\"].max())\\n\",\n",
    "    \"    forecast_file_name = f\\\"country_ghg_forecast_{start_year}_{end_year}.csv\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"evaluation_df.to_csv(\\\"country_model_evaluation.csv\\\", index=False)\\n\",\n",
    "    \"multi_year_df.to_csv(forecast_file_name, index=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Saved country_model_evaluation.csv: {len(evaluation_df)} rows\\\")\\n\",\n",
    "    \"print(f\\\"Saved {forecast_file_name}: {len(multi_year_df)} rows\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"display(evaluation_df)\\n\",\n",
    "    \"display(multi_year_df.head(20))\\n\"\n",
    "   ],\n",
